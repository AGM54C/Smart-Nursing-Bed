# ═══ 智能护理病床云平台 环境配置模板 ═══
# 复制为 .env 后填入真实值: cp .env.example .env

PORT=3000
JWT_SECRET=请改成随机长字符串
DEVICE_API_KEY=树莓派与云端的共享密钥

# ══ 统一 LLM 网关 (services/llm.js) ══
# 降级链: 涂鸦智能体 → Moonshot kimi-k3 → SiliconFlow (上一级失败自动落下一级, 演示不中断)
# 体检: node scripts/probe_tuya_agent_api.js
LLM_PROVIDER=tuya
# LLM_FALLBACK=off                    # 关闭自动降级 (验收"纯涂鸦链路"时用)

# ── 第二级: Moonshot kimi-k3 主力大模型 (K2.5 已下架; 填 key 后本级自动启用) ──
# ⚠️ K3 需账户充值 (新用户15元代金券不适用); key 从 platform.kimi.com/console/api-keys 申请
MOONSHOT_API_KEY=
MOONSHOT_MODEL=kimi-k3
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# ── 第三级保底: SiliconFlow, siliconflow.cn 申请 (KIMI_* 为历史变量名; 语音流式链路直连本级) ──
KIMI_API_KEY=sk-你的SiliconFlow密钥
KIMI_BASE_URL=https://api.siliconflow.cn/v1
KIMI_MODEL=deepseek-ai/DeepSeek-V3
# 语音链路快模型 (kimi-k3 思考模式时延高, 语音调用自动跳过 K3 级)
VOICE_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
SILICONFLOW_API_KEY=sk-你的SiliconFlow密钥

# ── 涂鸦云项目授权密钥 (platform.tuya.com → 云开发 → 项目 → 授权密钥; ⚠️ 不是设备三元组!) ──
TUYA_OPENAPI_BASE=https://openapi.tuyacn.com
TUYA_ACCESS_ID=
TUYA_ACCESS_SECRET=

# ── 涂鸦智能体 ID (开发者工作台 → AI 智能体开发; 提示词: node scripts/export_agent_prompts.js) ──
TUYA_AGENT_ID=
TUYA_AGENT_ID_QUADRIPLEGIA=
TUYA_AGENT_ID_DIABETES=
TUYA_AGENT_ID_POST_STROKE=
TUYA_AGENT_ID_COPD=
TUYA_AGENT_ID_GENERAL=
# 对话接口真实路径 (云开发 → API Explorer → 智能体; probe 脚本探通后会提示该填什么)
# TUYA_AGENT_CHAT_PATH=/v2.0/cloud/agent/{agent_id}/chat
# TUYA_SEND_SYSTEM=1                  # 把本地系统提示词折叠进正文 (默认不发, 平台侧已配人设)
# TUYA_TIMEOUT_MS=15000               # 涂鸦阶段独立限时, 超时即降级

# ── 讯飞 实时语音转写 (ASR, console.xfyun.cn 申请) ──
XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_API_SECRET=
XFYUN_ASR_ENDPOINT=wss://office-api-ast-dz.iflyaisol.com/v1/ws

# ── 阿里云百炼 CosyVoice TTS (bailian.console.aliyun.com, 注意账户余额) ──
DASHSCOPE_API_KEY=
COSYVOICE_MODEL=cosyvoice-v3-flash
COSYVOICE_VOICE_ID=longanyang
